FROM python:3.9-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    curl \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件
COPY pyproject.toml setup.py ./
COPY agent_data ./agent_data

# 安装 Python 依赖
RUN pip install --no-cache-dir -e ".[nl2sql]"

# 暴露端口
EXPOSE 8000

# 启动命令
CMD ["uvicorn", "agent_data.web.app:app", "--host", "0.0.0.0", "--port", "8000"]
